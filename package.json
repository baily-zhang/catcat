{
  "name": "petsona-player",
  "version": "0.1.0",
  "description": "Transparent macOS desktop companion player for Pet Packs.",
  "author": "Petsona",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --mac zip",
    "dist:dmg": "electron-builder --mac dmg"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.petsona.player",
    "productName": "Petsona",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "pet.html",
      "panel.html",
      "sprite.webp",
      "frame_front.webp",
      "README.md",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
